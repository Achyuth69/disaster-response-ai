# ── Disaster Response AI System — Environment Configuration ──────────────────
# Copy this file to .env and fill in your values

# ── LLM (Groq — free tier, ultra-fast) ───────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Get free key at: https://console.groq.com
PRIMARY_MODEL=llama-3.3-70b-versatile
SECONDARY_MODEL=llama-3.1-8b-instant

# ── Paths ─────────────────────────────────────────────────────────────────────
CHECKPOINT_DIR=checkpoints
OUTPUT_DIR=output
FAISS_INDEX_DIR=faiss_index
KNOWLEDGE_BASE_DIR=knowledge_base

# ── Email Alerts (optional — Gmail SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
# Gmail App Password: Google Account → Security → 2FA → App Passwords

# ── SMS Alerts (optional — Twilio) ───────────────────────────────────────────
# TWILIO_SID=your_twilio_sid
# TWILIO_TOKEN=your_twilio_token
# TWILIO_FROM=+1234567890
